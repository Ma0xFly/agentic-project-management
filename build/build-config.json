{
  "build": {
    "sourceDir": "templates",
    "outputDir": "dist",
    "cleanOutput": true
  },
  "targets": [
    {
      "id": "copilot",
      "name": "GitHub Copilot",
      "description": "适配 GitHub Copilot",
      "bundleName": "copilot.zip",
      "format": "markdown",
      "configDir": ".github",
      "directories": {
        "commands": ".github/prompts",
        "skills": ".github/skills",
        "guides": ".github/apm-guides",
        "agents": ".github/agents"
      },
      "contextAttachSyntax": "使用 `#file` 引用文件，并从选择器中选中文件。",
      "newChatGuidance": "新开一个 Copilot Chat",
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "#runSubagent",
        "explorerName": "exploration",
        "configNote": null
      },
      "postInstallNote": null
    },
    {
      "id": "claude",
      "name": "Claude Code",
      "description": "适配 Claude Code",
      "bundleName": "claude.zip",
      "format": "markdown",
      "configDir": ".claude",
      "directories": {
        "commands": ".claude/commands",
        "skills": ".claude/skills",
        "guides": ".claude/apm-guides",
        "agents": ".claude/agents"
      },
      "contextAttachSyntax": "使用 `@` 加文件路径引用文件。",
      "newChatGuidance": "新开一个终端并启动 Claude Code",
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "Agent(subagent_type=\"Explore\", prompt=\"...\")",
        "explorerName": "Explore",
        "configNote": null
      },
      "postInstallNote": null
    },
    {
      "id": "gemini",
      "name": "Gemini CLI",
      "description": "适配 Gemini CLI",
      "bundleName": "gemini.zip",
      "format": "toml",
      "configDir": ".gemini",
      "directories": {
        "commands": ".gemini/commands",
        "skills": ".gemini/skills",
        "guides": ".gemini/apm-guides",
        "agents": ".gemini/agents"
      },
      "contextAttachSyntax": "使用 `@` 加文件路径引用文件。",
      "newChatGuidance": "新开一个终端并启动 Gemini CLI",
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "@codebase_investigator <natural language query>",
        "explorerName": "codebase_investigator",
        "configNote": "需要在 ~/.gemini/settings.json 中设置 `experimental.enableAgents: true`"
      },
      "postInstallNote": "Gemini CLI 需要在 ~/.gemini/settings.json 中设置 `experimental.enableAgents: true` 才能使用 subagent 功能。"
    },
    {
      "id": "cursor",
      "name": "Cursor",
      "description": "适配 Cursor",
      "bundleName": "cursor.zip",
      "format": "markdown",
      "configDir": ".cursor",
      "directories": {
        "commands": ".cursor/commands",
        "skills": ".cursor/skills",
        "guides": ".cursor/apm-guides",
        "agents": ".cursor/agents"
      },
      "contextAttachSyntax": "使用 `@` 并搜索文件名来引用文件。",
      "newChatGuidance": "新开一个 Cursor Agent chat",
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "Task(subagent_type=\"explore\", prompt=\"...\")",
        "explorerName": "explore",
        "configNote": null
      },
      "postInstallNote": null
    },
    {
      "id": "opencode",
      "name": "OpenCode",
      "description": "适配 OpenCode",
      "bundleName": "opencode.zip",
      "format": "markdown",
      "configDir": ".opencode",
      "directories": {
        "commands": ".opencode/commands",
        "skills": ".opencode/skills",
        "guides": ".opencode/apm-guides",
        "agents": ".opencode/agents"
      },
      "contextAttachSyntax": "使用 `@` 加文件名引用文件。",
      "newChatGuidance": "新开一个终端并启动 OpenCode",
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "Task(subagent_type=\"explore\", prompt=\"...\")",
        "explorerName": "explore",
        "configNote": null
      },
      "postInstallNote": null
    },
    {
      "id": "codex",
      "name": "Codex CLI",
      "description": "适配 Codex CLI",
      "bundleName": "codex.zip",
      "format": "markdown",
      "configDir": ".codex",
      "directories": {
        "commands": ".agents/skills",
        "skills": ".agents/skills",
        "guides": ".codex/apm-guides",
        "agents": ".codex/agents"
      },
      "contextAttachSyntax": "使用 `@` 加文件路径引用文件。",
      "newChatGuidance": "新开一个终端并启动 Codex CLI",
      "subagentGuidance": {
        "hasSubagents": true,
        "toolSyntax": "spawn_agent(agent_type=\"explorer\", message=\"...\")",
        "explorerName": "explorer",
        "configNote": null
      },
      "postInstallNote": "Codex CLI 不支持自定义 slash commands。APM 命令会以 skills 形式安装，并使用 $ 前缀调用，例如 $apm-1-initiate-planner。"
    }
  ]
}
